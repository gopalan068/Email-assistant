# ==============================================================================
# Mail Assist Environment Configuration Configuration
# ==============================================================================

# Port the Flask server will bind to
PORT=5000

# Gemini API credentials
# Generate your key here: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# LLM Model identifier (Defaults to gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash
