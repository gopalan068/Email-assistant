# ==============================================================================
# Mail Assist Environment Configuration Configuration
# ==============================================================================

# Port the Flask server will bind to
PORT=5000

# Groq API credentials
# Generate your key in your Groq console (https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# LLM Model identifier (e.g. meta-llama/llama-4-scout-17b-16e-instruct)
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Google OAuth JSON Strings (Optional for local, required for headless cloud deploys like Render)
# Minified JSON contents of backend/token.json
GMAIL_TOKEN_JSON=your_minified_token_json_here
# Minified JSON contents of credentials.json
GMAIL_CREDENTIALS_JSON=your_minified_credentials_json_here

